{
  "name": "astro-auth-boilerplate",
  "type": "module",
  "version": "0.0.1",
  "description": "Astro boilerplate with Better Auth, Turso, Bun, and a pragmatic Feature-Sliced structure.",
  "license": "MIT",
  "keywords": [
    "astro",
    "better-auth",
    "turso",
    "drizzle",
    "react",
    "tailwindcss",
    "boilerplate",
    "feature-sliced-design"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "postinstall": "node tools/patch-libsql-punycode.js",
    "setup": "node tools/setup.js",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "test": "bun test",
    "astro": "astro",
    "doctor": "astro check && drizzle-kit check && bun audit --prod --audit-level=high && astro build --silent",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "auth:generate": "NODE_NO_WARNINGS=1 better-auth generate --config src/shared/api/auth/server.ts --output src/shared/api/db/schema/auth.ts --yes"
  },
  "dependencies": {
    "@astrojs/node": "^10.0.1",
    "@astrojs/react": "^5.0.0",
    "@libsql/client": "^0.17.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.1",
    "astro": "^6.0.4",
    "better-auth": "1.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@better-auth/cli": "1.4.21",
    "@astrojs/check": "^0.9.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
