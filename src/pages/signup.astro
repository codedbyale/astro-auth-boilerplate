---
import RootLayout from "@/app/layouts/root-layout.astro";
import { getServerSession } from "@/features/auth/api/get-server-session";
import { AuthForm } from "@/features/auth/ui/auth-form";

const session = await getServerSession(Astro.request);

if (session) {
	return Astro.redirect("/dashboard");
}
---

<RootLayout title="Create Account | Astro Auth Boilerplate">
	<div class="mx-auto flex min-h-screen max-w-6xl items-center px-6 py-10 sm:px-10 lg:px-12">
		<div class="grid w-full gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
			<section class="space-y-6">
				<a class="text-sm font-medium text-primary underline-offset-4 hover:underline" href="/">
					Back to home
				</a>
				<div class="space-y-4">
					<p class="text-sm font-medium uppercase tracking-[0.22em] text-muted-foreground">
						Astro + Better Auth
					</p>
					<h2 class="max-w-xl text-4xl font-semibold tracking-tight text-foreground sm:text-5xl">
						Create the first account and bootstrap a real session.
					</h2>
					<p class="max-w-xl text-base leading-7 text-muted-foreground sm:text-lg">
						Your auth schema and database are already wired. This page creates the credential
						user and signs in immediately.
					</p>
				</div>
			</section>

			<AuthForm client:load mode="signup" redirectTo="/dashboard" />
		</div>
	</div>
</RootLayout>
